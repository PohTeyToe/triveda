{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "echo 'Skipping build -- Bun runs TypeScript directly'"
  },
  "deploy": {
    "runtime": "V2",
    "startCommand": "bun run apps/api/src/index.ts",
    "healthcheckPath": "/healthz",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
