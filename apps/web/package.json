{
  "name": "@triveda/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "e2e:desktop": "playwright test --project=desktop-chrome --project=desktop-firefox",
    "e2e:core": "playwright test tests/e2e/core-flows.spec.ts",
    "e2e:install": "playwright install chromium firefox webkit",
    "test:visual": "playwright test tests/visual/",
    "test:visual:update": "playwright test tests/visual/ --update-snapshots",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@fontsource/crimson-pro": "^5.2.5",
    "@fontsource/dm-sans": "^5.2.5",
    "@hookform/resolvers": "^5.2.2",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@supabase/supabase-js": "^2.49.0",
    "@tanstack/react-query": "^5.75.5",
    "@tanstack/react-router": "^1.121.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@triveda/api-client": "workspace:*",
    "@triveda/shared": "workspace:*",
    "framer-motion": "^12.35.1",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.72.1",
    "sonner": "^2.0.7",
    "vaul": "^1.1.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/router-devtools": "^1.121.0",
    "@tanstack/router-plugin": "^1.121.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vercel/node": "^5.7.4",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.1",
    "vite": "^6.3.2",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^4.1.4"
  }
}
