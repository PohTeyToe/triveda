{
  "name": "triveda",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/shared/api-client"
  ],
  "scripts": {
    "dev": "pnpm --filter @triveda/web dev & pnpm --filter @triveda/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepare": "husky",
    "seed-demo": "bun run scripts/seed-demo-user.ts",
    "smoke": "bun run scripts/smoke-production.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["biome check --write"]
  },
  "devDependencies": {
    "@biomejs/biome": "~1.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "5.9.3"
  }
}
