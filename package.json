{
  "name": "triveda",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --filter @triveda/web dev & pnpm --filter @triveda/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["biome check --write"]
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "6.0.2"
  }
}
